{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=${DB_HOST};port=${DB_PORT};Database=${DB_NAME};Username=${DB_USER};Password=${DB_PASSWORD}"
  },
  "AllowedHosts": "*",
  "Jwt": { 
    "Issuer": "ProductsApi",
    "Audience": "ProductsApiUsers",
    "ExpiresInMinutes": 60
  }
}